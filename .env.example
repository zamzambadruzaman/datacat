# datacat configuration — copy to .env and fill in your values

# ── Required secrets (change before deploying) ────────────────────────────────
# Shared secret for write endpoints (X-API-KEY header)
API_KEY=your-api-key-here

# Secret used to sign JWT tokens — use a long random string
JWT_SECRET=your-jwt-secret-here

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=/data/catalog.duckdb

# ── HTTP / CORS ───────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Auth ──────────────────────────────────────────────────────────────────────
# Set to true to require authentication on read (GET) endpoints
AUTH_READ_ENDPOINTS=false

# ── Demo / development only ───────────────────────────────────────────────────
# Enables the POST /api/test/seed-data endpoint (DELETES ALL DATA — never enable in production)
ENABLE_TEST_DATA_ENDPOINT=false

# Default user email used in tests and local dev
DEFAULT_USER_EMAIL=user@example.com

# ── Email / SMTP (optional — for access-request notifications) ────────────────
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@datacat.local
